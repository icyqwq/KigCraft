APP_ENV=development
API_HOST=0.0.0.0
API_PORT=18000
FRONTEND_PORT=15173

# Keep local development services bound to localhost by default.
POSTGRES_BIND_HOST=127.0.0.1
REDIS_BIND_HOST=127.0.0.1
MINIO_BIND_HOST=127.0.0.1
API_BIND_HOST=127.0.0.1
FRONTEND_BIND_HOST=127.0.0.1
CORS_ALLOWED_ORIGINS=
TRUSTED_PROXY_HOSTS=127.0.0.1,::1
GENERATION_CREATE_RATE_LIMIT_WINDOW_SECONDS=300
GENERATION_CREATE_RATE_LIMIT_MAX_REQUESTS=3

POSTGRES_DB=kig_preview
POSTGRES_USER=kig
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+asyncpg://kig:change-me-postgres-password@postgres:5432/kig_preview
REDIS_URL=redis://redis:6379/0

MINIO_ROOT_USER=kig_minio
MINIO_ROOT_PASSWORD=change-me-minio-password
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:19000
S3_ACCESS_KEY_ID=kig_minio
S3_SECRET_ACCESS_KEY=change-me-minio-password
S3_BUCKET=kig-preview

JWT_SECRET=change-me-generate-a-long-random-secret
MOCK_SMS_CODE=000000
ADMIN_AUDIT_PASSWORD=change-me-admin-audit-password

GENERATION_PROVIDER=codex
ALLOW_FIXTURE_GENERATION=false
MOCK_OUTPUT_DIR=runtime/mock-outputs
CODEX_PATH=codex
CODEX_CONFIG_DIR=./runtime/codex-home
CODEX_BRIDGE_URL=http://host.docker.internal:18100
CODEX_BRIDGE_TOKEN=change-me-local-bridge-token
CODEX_BRIDGE_TIMEOUT_SECONDS=1800
CODEX_WORKSPACE_DIR=runtime/codex
CODEX_OUTPUT_DIR=runtime/generated
REFERENCE_UPLOAD_DIR=runtime/references
CODEX_PRODUCT_REFERENCE_PATH=ref/product-reference.png
GENERATED_PUBLIC_PREFIX=/api/generated

WATERMARK_TEXT=KigCraft AI generated
WATERMARK_DOMAIN_TEXT=KigCraft

MAX_PROVIDER_CONCURRENCY=8
NORMAL_QUOTA_WINDOW_HOURS=5
NORMAL_BASE_QUOTA=2
